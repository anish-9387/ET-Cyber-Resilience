# ---------------------------------------------------------------------------
# Sentinel configuration
#
# Every key below maps 1:1 to a field on backend/app/core/config.py::Settings.
# Nothing here is required to run the demo: with no .env at all the backend
# falls back to a local SQLite file and disables Neo4j/Qdrant/Redis gracefully.
# ---------------------------------------------------------------------------

# Database. Leave as SQLite for a standalone demo.
# DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db

# Optional graph store. Disabled automatically if unreachable.
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Optional vector store. Disabled automatically if unreachable.
QDRANT_ENABLED=false
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Optional event bus / cache. Disabled automatically if unreachable.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM. Optional - reasoning falls back to deterministic logic when unavailable.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Application
APP_NAME=Sentinel
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# World model
WORLD_MODEL_SEED_ON_STARTUP=true
EVIDENCE_HALF_LIFE_HOURS=6.0
DETECTION_THRESHOLD=0.6
HUMAN_APPROVAL_REQUIRED=true

# Frontend (read by Next.js - note the /v1 suffix)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
