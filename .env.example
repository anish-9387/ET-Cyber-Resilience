# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sentinelx
POSTGRES_DB=sentinelx
POSTGRES_USER=sentinelx
POSTGRES_PASSWORD=sentinelx_secret_2024

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sentinelx_redis

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM / AI
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# App
APP_NAME=Sentinel-X
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Digital Twin
TWIN_SYNC_INTERVAL=30

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_METRICS=true
